    "jsdom": "^29.0.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.58.0",
    "vite": "^6.4.1",
    "vitest": "^4.1.2"
  },
  "dependencies": {
    "phaser": "^3.90.0"
  }
}
